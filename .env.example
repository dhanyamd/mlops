# ── PostgreSQL (OLTP catalog) ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops
POSTGRES_DB=mlops

# ── ClickHouse (OLAP warehouse) ─────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redis (online feature store) ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Qdrant (vector DB — fraud pattern similarity) ───────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_FRAUD_COLLECTION=fraud_patterns

# ── Kafka (event streaming) ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRANSACTIONS_TOPIC=transactions
KAFKA_FEATURES_TOPIC=transaction_features
KAFKA_PREDICTIONS_TOPIC=fraud_predictions
KAFKA_ALERTS_TOPIC=fraud_alerts

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_MASTER=spark://localhost:7077

# ── MLflow + S3 (MinIO) ─────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
MLFLOW_ALLOW_FILE_STORE=true
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── Prefect ─────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ── Data lake (raw downloads cache) ───────────────────────────────────────────
DATA_LAKE=./data_lake
MLOPS_SAMPLE_ROWS=50000

# Real dataset URLs
STORE_SALES_URL=https://raw.githubusercontent.com/skforecast/skforecast-datasets/main/data/store_sales.csv
CREDIT_CARD_FRAUD_URL=https://raw.githubusercontent.com/SimoCs/Fraudulent-Transactions-Java/main/creditcard.csv
