{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "ML Model Health — Fraud Detection + Demand Forecasting",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔴 Fraud Detection — Real-Time Inference",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(mlops_fraud_predictions_total[5m])",
          "legendFormat": "{{result}} predictions/s",
          "refId": "A"
        }
      ],
      "title": "Fraud Prediction Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          },
          "unit": "s",
          "mappings": []
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(mlops_fraud_inference_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(mlops_fraud_inference_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, rate(mlops_fraud_inference_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "C"
        }
      ],
      "title": "Inference Latency (p50 / p95 / p99)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.15 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "expr": "mlops_fraud_rate_rolling",
          "legendFormat": "{{model_version}}",
          "refId": "A"
        }
      ],
      "title": "Rolling Fraud Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(mlops_redis_feature_fetch_seconds_bucket[5m]))",
          "legendFormat": "Redis p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(mlops_redis_feature_fetch_seconds_bucket[5m]))",
          "legendFormat": "Redis p50",
          "refId": "B"
        }
      ],
      "title": "Redis Feature Store Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(mlops_redis_feature_misses_total[5m])",
          "legendFormat": "Cache misses/s",
          "refId": "A"
        }
      ],
      "title": "Redis Cache Miss Rate",
      "description": "High miss rate = feature store not materialized. Run: make feast-materialize",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "HEALTHY" }, "1": { "text": "OPEN (DEGRADED)" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 17 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "expr": "mlops_circuit_breaker_open",
          "legendFormat": "{{service}} circuit breaker",
          "refId": "A"
        }
      ],
      "title": "Circuit Breaker State",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 101,
      "title": "📊 Model Performance & Drift",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 22 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        { "expr": "mlops_model_auc", "legendFormat": "AUC — {{project}}", "refId": "A" },
        { "expr": "mlops_model_f1", "legendFormat": "F1 — {{project}}", "refId": "B" }
      ],
      "title": "Champion Model Scores",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 22 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "expr": "mlops_feature_drift_ks_statistic",
          "legendFormat": "{{feature_name}} ({{project}})",
          "refId": "A"
        }
      ],
      "title": "Feature Drift (KS Statistic) — Red = retrain triggered",
      "description": "KS statistic > 0.3 triggers automatic retraining via Prefect.",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 102,
      "title": "🔵 Demand Forecasting — Batch Pipeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 29 },
      "id": 9,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        { "expr": "mlops_forecast_mape", "legendFormat": "MAPE — {{model_name}}", "refId": "A" }
      ],
      "title": "Forecast MAPE (lower is better)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "FAILED ❌" }, "1": { "text": "PASSED ✅" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 29 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        { "expr": "mlops_data_quality_gate", "legendFormat": "{{project}} — {{checkpoint}}", "refId": "A" }
      ],
      "title": "Data Quality Gates",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 29 },
      "id": 11,
      "targets": [
        {
          "expr": "mlops_training_duration_seconds_sum / mlops_training_duration_seconds_count",
          "legendFormat": "Avg training time — {{project}}",
          "refId": "A"
        }
      ],
      "title": "Training Pipeline Duration",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["mlops", "fraud", "forecasting"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ML Model Health",
  "uid": "mlops-model-health",
  "version": 1
}
